# Flask Configuration
APP_ENV=development
FLASK_DEBUG=1
HOST=0.0.0.0
PORT=5000

# Site Configuration
SITE_NAME=Your Name
SITE_TAGLINE=Your tagline here
SITE_EMAIL=you@example.com
# IMPORTANT: Set this to your production domain (e.g. https://example.com).
# Used for canonical URLs and OG/Twitter meta tags.
SITE_URL=
SITE_META_DESCRIPTION=Your site description here.
ASSET_VERSION=1

# Security — change this in production!
SECRET_KEY=dev-secret-change-in-production

# Database — SQLite by default, override for PostgreSQL in production
# e.g. postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///blog.db

# Analytics (optional)
PLAUSIBLE_SCRIPT_URL=
PLAUSIBLE_DOMAIN=

# Social image (optional)
SITE_SOCIAL_IMAGE=

# Deployment
BASE_PATH=
GITHUB_PAGES_BASE_PATH=
